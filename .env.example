# =============================================================================
# SupportBrainAI — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- LLM Chat Model ---
# Model identifier (format depends on provider)
MODEL_NAME=openai:/gpt-4o-mini
# LangChain model provider: openai, anthropic, google, ollama, etc.
MODEL_PROVIDER=openai
# API key for the LLM provider (or proxy/gateway)
API_KEY=your-api-key-here
# Custom base URL (optional — for proxies, gateways, LiteLLM)
BASE_URL=

# --- LLM Embeddings ---
# Embedding model name (optional — only needed for RAG/search features)
EMBEDDING_MODEL_NAME=text-embedding-3-small
# Embedding provider: openai, huggingface, cohere, etc.
EMBEDDING_PROVIDER=openai

# --- LLM Defaults ---
DEFAULT_TEMPERATURE=0.0
DEFAULT_MAX_TOKENS=4096

# --- Application ---
DEBUG=false
