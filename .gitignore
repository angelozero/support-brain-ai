# =============================================================================
# SupportBrainAI — .gitignore
# =============================================================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
*.whl

# --- UV / Virtual Environment ---
.venv/
uv.lock

# --- Environment / Secrets ---
.env
.env.local
.env.*.local
*.pem
*.key

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# --- OS ---
.DS_Store
Thumbs.db
Desktop.ini

# --- Testing ---
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover

# --- Ruff ---
.ruff_cache/

# --- Mypy ---
.mypy_cache/
.dmypy.json
dmypy.json

# --- Jupyter Notebooks ---
.ipynb_checkpoints/

# --- MLflow ---
mlruns/
mlartifacts/

# --- Data / Models (large files) ---
*.db
*.sqlite3
data/
models/
*.parquet
*.arrow

# --- Docker ---
docker-compose.override.yml

# --- Logs ---
*.log
logs/

# --- Misc ---
.cache/
tmp/
temp/
